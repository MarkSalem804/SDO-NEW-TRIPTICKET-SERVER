<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;700;800&family=UnifrakturMaguntia&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: "Crimson Pro", serif;
            margin: 5px 20px 20px 20px;
            color: #000;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
        }
        .header img {
            width: 100%;
            max-width: 650px;
            height: auto;
        }
        .old-english {
            font-family: "UnifrakturMaguntia", serif;
            font-size: 20px;
            font-weight: bold;
            line-height: 1;
            margin-bottom: -2px;
        }
        .dept-title {
            font-family: "UnifrakturMaguntia", serif;
            font-size: 24px;
            font-weight: bold;
            line-height: 1;
            margin-bottom: 2px;
        }
        .sub-dept {
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            line-height: 1.2;
        }
        .title {
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 20px 0 5px 0;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }
        th, td {
            border: 1px solid #ccc;
            padding: 10px 5px;
            text-align: left;
        }
        th {
            background-color: #f9f9f9;
            text-transform: uppercase;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="header">
        <img src="{{headerBase64}}" alt="Header">
    </div>

    <div class="title">Monthly Trip Logs</div>
    <div style="text-align: center; margin-bottom: 20px; font-size: 12px;">Period: {{month}}</div>

    <table>
        <thead>
            <tr>
                <th>Requestor</th>
                <th>Trip Ticket ID</th>
                <th>Passengers</th>
                <th>Departure</th>
                <th>Arrival</th>
                <th>Destination</th>
            </tr>
        </thead>
        <tbody>
            {{#each travels}}
            <tr>
                <td>{{requestor}}</td>
                <td>{{tripticketId}}</td>
                <td>{{passengers}}</td>
                <td>{{departure}}</td>
                <td>{{arrival}}</td>
                <td>{{destination}}</td>
            </tr>
            {{/each}}
            {{#unless travels}}
            <tr>
                <td colspan="6" style="text-align: center;">No trip logs found for this period.</td>
            </tr>
            {{/unless}}
        </tbody>
    </table>
</body>
</html>
